{
  "name": "palouse",
  "version": "0.0.0",
  "private": true,
  "description": "Palouse — team task aggregation + agentic handoff platform",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @palouse/db migrate",
    "db:generate": "pnpm --filter @palouse/db generate",
    "palouse": "pnpm --filter @palouse/cli dev",
    "db:seed": "pnpm --filter @palouse/cli dev seed"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ],
    "overrides": {
      "bullmq": "5.78.0",
      "ioredis": "5.10.1",
      "postcss": ">=8.5.10"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "all"
  }
}
