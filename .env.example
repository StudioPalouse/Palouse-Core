# --- Core ---
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres ---
DATABASE_URL=postgres://reqops:reqops@localhost:5432/reqops

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Better-Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
BETTER_AUTH_URL=http://localhost:4000

# --- API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
# Exposed to the browser by Next.js — must match API_BASE_URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Encryption (AES-256-GCM for connector OAuth tokens at rest) ---
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars)
REQOPS_ENCRYPTION_KEY=replace-me-with-64-hex-chars-from-openssl-rand-hex-32

# --- MCP server ---
MCP_HTTP_PORT=7777
REQOPS_API_URL=http://localhost:4000

# --- Object storage (S3-compatible; defaults to local minio in compose) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=reqops
S3_ACCESS_KEY=reqops
S3_SECRET_KEY=reqops-dev-secret

# --- Connector OAuth (self-host: register your own apps and paste here) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=

# --- Optional: social login providers for Better-Auth ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
