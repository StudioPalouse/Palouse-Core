# --- Core ---
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres ---
DATABASE_URL=postgres://palouse:palouse@localhost:5432/palouse

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Better-Auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
# Public origin for auth = the WEB origin: browsers reach the API through the
# Next rewrite proxy so cookies stay first-party.
BETTER_AUTH_URL=http://localhost:3000
# Set to true to reject sign-ups from public email providers (gmail.com,
# outlook.com, yahoo.com, …). The hosted cloud enables this; self-hosting
# leaves it off so any address works.
AUTH_BLOCK_PUBLIC_EMAIL_DOMAINS=false
# Comma-separated extra domains to reject, applied even when the flag is off.
AUTH_BLOCKED_EMAIL_DOMAINS=

# --- API ---
API_PORT=4000
# Publicly reachable base for OAuth callbacks + webhooks — the web proxy origin.
API_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3000
# Empty = same-origin (browser API calls ride the Next rewrite proxy).
# Only set this to point the browser at an API origin directly.
NEXT_PUBLIC_API_URL=
# Where the Next server forwards proxied API paths (next.config.mjs rewrites).
API_PROXY_TARGET=http://localhost:4000

# --- Encryption (AES-256-GCM for connector OAuth tokens at rest) ---
# Generate with: openssl rand -hex 32  (must be exactly 64 hex chars)
PALOUSE_ENCRYPTION_KEY=replace-me-with-64-hex-chars-from-openssl-rand-hex-32

# --- MCP server ---
MCP_HTTP_PORT=7777
PALOUSE_API_URL=http://localhost:4000

# --- Object storage (S3-compatible; defaults to local minio in compose) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=palouse
S3_ACCESS_KEY=palouse
S3_SECRET_KEY=palouse-dev-secret

# --- Transactional mail (Resend) ---
# Empty = mail sends are logged no-ops (fine for local dev / bare self-host).
# Key from https://resend.com/api-keys; MAIL_FROM needs a Resend-verified
# domain for real delivery (the default onboarding sender only delivers to
# the Resend account owner).
RESEND_API_KEY=
MAIL_FROM=Palouse <onboarding@resend.dev>

# --- Connector OAuth (self-host: register your own apps and paste here) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
TODOIST_OAUTH_CLIENT_ID=
TODOIST_OAUTH_CLIENT_SECRET=

# --- Optional: social login providers for Better-Auth ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_MICROSOFT_CLIENT_ID=
AUTH_MICROSOFT_CLIENT_SECRET=
