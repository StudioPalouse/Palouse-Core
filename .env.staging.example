# Staging secrets — copied to Fly apps by scripts/fly-secrets.sh (never committed).
#   cp .env.staging.example .env.staging   # then fill in and run ./scripts/fly-secrets.sh
#
# Only secrets live here. Non-secret config (URLs, ports, NODE_ENV) is set per-app
# in fly/*.toml [env] blocks.

# --- Postgres: Fly Managed Postgres cluster "palouse-staging-db" (iad) ---
# DATABASE_URL is NOT set here. It is owned by Fly Managed Postgres and injected
# into each backend app as a secret by `fly mpg attach` (run from
# scripts/fly-provision.sh). To inspect or rotate it:
#   fly mpg list --org palouse           # cluster id
#   fly secrets list --app palouse-staging-api | grep DATABASE_URL
#   fly mpg connect <cluster-id>         # ad-hoc psql
# Because attach owns DATABASE_URL, fly-secrets.sh must not also push it.

# --- Redis: Fly-managed Upstash, created by scripts/fly-provision.sh ---
# URL printed at create time, or recover with: fly redis status palouse-staging-redis
# BullMQ requires eviction to stay DISABLED on this database.
REDIS_URL=rediss://default:<PASSWORD>@fly-palouse-staging-redis.upstash.io:6379

# --- Auth / crypto ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=
# openssl rand -hex 32  (exactly 64 hex chars)
PALOUSE_ENCRYPTION_KEY=

# --- Transactional mail (Resend) ---
# Create an API key at https://resend.com/api-keys. Leave empty to disable
# mail (sends become logged no-ops). For real delivery beyond the account
# owner's inbox, verify the sending domain in the Resend dashboard and set
# MAIL_FROM in fly/*.toml [env] (it's not a secret), e.g.:
#   MAIL_FROM=Palouse <no-reply@palouse.io>
RESEND_API_KEY=

# --- Connector OAuth (fill in when testing connectors against staging) ---
# Redirect URIs must point at https://palouse-staging-api.fly.dev/oauth/<provider>/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
