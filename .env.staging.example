# Staging secrets — copied to Fly apps by scripts/fly-secrets.sh (never committed).
#   cp .env.staging.example .env.staging   # then fill in and run ./scripts/fly-secrets.sh
#
# Only secrets live here. Non-secret config (URLs, ports, NODE_ENV) is set per-app
# in fly/*.toml [env] blocks.

# --- Postgres: Fly Postgres app "reqops-staging-db" (single node, iad) ---
# Created by scripts/fly-provision.sh. The reqops_app role password is set at
# CREATE ROLE time (see the provision script); reset via:
#   fly postgres connect -a reqops-staging-db
#   ALTER ROLE reqops_app PASSWORD '<new>';
# .flycast is Fly-private networking — no TLS, hence sslmode=disable. Only apps
# in the reqops org can reach it.
DATABASE_URL=postgresql://reqops_app:<DB_PASSWORD>@reqops-staging-db.flycast:5432/reqops?sslmode=disable

# --- Redis: Fly-managed Upstash, created by scripts/fly-provision.sh ---
# URL printed at create time, or recover with: fly redis status reqops-staging-redis
# BullMQ requires eviction to stay DISABLED on this database.
REDIS_URL=rediss://default:<PASSWORD>@fly-reqops-staging-redis.upstash.io:6379

# --- Auth / crypto ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=
# openssl rand -hex 32  (exactly 64 hex chars)
REQOPS_ENCRYPTION_KEY=

# --- Transactional mail (Resend) ---
# Create an API key at https://resend.com/api-keys. Leave empty to disable
# mail (sends become logged no-ops). For real delivery beyond the account
# owner's inbox, verify the sending domain in the Resend dashboard and set
# MAIL_FROM in fly/*.toml [env] (it's not a secret), e.g.:
#   MAIL_FROM=ReqOps <no-reply@reqops.ai>
RESEND_API_KEY=

# --- Connector OAuth (fill in when testing connectors against staging) ---
# Redirect URIs must point at https://reqops-staging-api.fly.dev/oauth/<provider>/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
