# Staging secrets — copied to Fly apps by scripts/fly-secrets.sh (never committed).
#   cp .env.staging.example .env.staging   # then fill in and run ./scripts/fly-secrets.sh
#
# Only secrets live here. Non-secret config (URLs, ports, NODE_ENV) is set per-app
# in fly/*.toml [env] blocks.

# --- Postgres: Supabase project "reqops-staging" (ref sbjosayjlbcvgevobwlj, us-east-1) ---
# Password: Supabase dashboard -> Project Settings -> Database -> Reset database password.
# Direct connection is IPv6-only on the free tier; Fly machines have outbound IPv6, so it works.
# If you ever need IPv4, switch to the session pooler URL shown in the dashboard
# (user becomes postgres.sbjosayjlbcvgevobwlj). Do NOT use the transaction pooler
# (port 6543) — it breaks migrations and LISTEN/NOTIFY.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.sbjosayjlbcvgevobwlj.supabase.co:5432/postgres

# --- Redis: Fly-managed Upstash, created by scripts/fly-provision.sh ---
# URL printed at create time, or recover with: fly redis status reqops-staging-redis
# BullMQ requires eviction to stay DISABLED on this database.
REDIS_URL=rediss://default:<PASSWORD>@fly-reqops-staging-redis.upstash.io:6379

# --- Auth / crypto ---
# openssl rand -base64 32
BETTER_AUTH_SECRET=
# openssl rand -hex 32  (exactly 64 hex chars)
REQOPS_ENCRYPTION_KEY=

# --- Connector OAuth (fill in when testing connectors against staging) ---
# Redirect URIs must point at https://reqops-staging-api.fly.dev/oauth/<provider>/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ASANA_OAUTH_CLIENT_ID=
ASANA_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
